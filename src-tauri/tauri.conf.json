{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Millennium Clipboard",
  "version": "0.10.1",
  "identifier": "com.guidocameraeq.millennium",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Millennium Clipboard // GRID",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 540,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
